// -----------------------------------------------------------------------
// MPR computation  (RFC 3626 §8.3)
// -----------------------------------------------------------------------

namespace
{
void
CoverTwoHopNeighbors(Ipv4Address neighborMainAddr, TwoHopNeighborSet& N2)
{
    std::set<Ipv4Address> toRemove;
    for (const auto& t : N2)
    {
        if (t.neighborMainAddr == neighborMainAddr)
        {
            toRemove.insert(t.twoHopNeighborAddr);
        }
    }
    for (auto it = N2.begin(); it != N2.end();)
    {
        it = toRemove.count(it->twoHopNeighborAddr) ? N2.erase(it) : std::next(it);
    }
}
} // unnamed namespace

void
RoutingProtocol::MprComputation()
{
    NS_LOG_FUNCTION(this);

    MprSet mprSet;

    NeighborSet N;
    for (const auto& nb : m_state.GetNeighbors())
    {
        if (nb.status == NeighborTuple::STATUS_SYM)
        {
            N.push_back(nb);
        }
    }

    TwoHopNeighborSet N2;
    for (const auto& twoHop : m_state.GetTwoHopNeighbors())
    {
        if (twoHop.twoHopNeighborAddr == m_mainAddress)
        {
            continue;
        }
        bool ok = false;
        for (const auto& neigh : N)
        {
            if (neigh.neighborMainAddr == twoHop.neighborMainAddr)
            {
                ok = (neigh.willingness != Willingness::NEVER);
                break;
            }
        }
        if (!ok)
        {
            continue;
        }
        for (const auto& neigh : N)
        {
            if (neigh.neighborMainAddr == twoHop.twoHopNeighborAddr)
            {
                ok = false;
                break;
            }
        }
        if (ok)
        {
            N2.push_back(twoHop);
        }
    }

    // Step 1: always-willing neighbors
    for (const auto& neigh : N)
    {
        if (neigh.willingness == Willingness::ALWAYS)
        {
            mprSet.insert(neigh.neighborMainAddr);
            CoverTwoHopNeighbors(neigh.neighborMainAddr, N2);
        }
    }

    // Step 3: single-coverage nodes
    std::set<Ipv4Address> covered;
    for (const auto& twoHop : N2)
    {
        bool onlyOne = true;
        for (const auto& other : N2)
        {
            if (other.twoHopNeighborAddr == twoHop.twoHopNeighborAddr &&
                other.neighborMainAddr != twoHop.neighborMainAddr)
            {
                onlyOne = false;
                break;
            }
        }
        if (onlyOne)
        {
            mprSet.insert(twoHop.neighborMainAddr);
            for (const auto& other : N2)
            {
                if (other.neighborMainAddr == twoHop.neighborMainAddr)
                {
                    covered.insert(other.twoHopNeighborAddr);
                }
            }
        }
    }
    for (auto it = N2.begin(); it != N2.end();)
    {
        it = covered.count(it->twoHopNeighborAddr) ? N2.erase(it) : std::next(it);
    }

    // Step 4: greedy coverage
    while (!N2.empty())
    {
        std::map<int, std::vector<const NeighborTuple*>> reachability;
        std::set<int> rs;
        for (const auto& nb : N)
        {
            int r = 0;
            for (const auto& t2 : N2)
            {
                if (nb.neighborMainAddr == t2.neighborMainAddr)
                {
                    r++;
                }
            }
            rs.insert(r);
            reachability[r].push_back(&nb);
        }

        const NeighborTuple* best = nullptr;
        int bestR = 0;
        for (int r : rs)
        {
            if (r == 0)
            {
                continue;
            }
            for (const NeighborTuple* nb : reachability[r])
            {
                if (best == nullptr || nb->willingness > best->willingness)
                {
                    best = nb;
                    bestR = r;
                }
                else if (nb->willingness == best->willingness)
                {
                    if (r > bestR || (r == bestR && Degree(*nb) > Degree(*best)))
                    {
                        best = nb;
                        bestR = r;
                    }
                }
            }
        }
        if (best != nullptr)
        {
            mprSet.insert(best->neighborMainAddr);
            CoverTwoHopNeighbors(best->neighborMainAddr, N2);
        }
    }

    m_state.SetMprSet(mprSet);
}

// -----------------------------------------------------------------------
// Routing table computation  (RFC 3626 §10)
// -----------------------------------------------------------------------

void
RoutingProtocol::RoutingTableComputation()
{
    NS_LOG_DEBUG(Simulator::Now().As(Time::S)
                 << " : Node " << m_mainAddress << ": RoutingTableComputation begin...");

    m_routingTable.Clear();

    // h=1: symmetric neighbors
    for (const auto& nb_tuple : m_state.GetNeighbors())
    {
        if (nb_tuple.status != NeighborTuple::STATUS_SYM)
        {
            continue;
        }
        bool nb_main_addr = false;
        const LinkTuple* lt = nullptr;
        for (const auto& link_tuple : m_state.GetLinks())
        {
            if (GetMainAddress(link_tuple.neighborIfaceAddr) == nb_tuple.neighborMainAddr &&
                link_tuple.time >= Simulator::Now())
            {
                lt = &link_tuple;
                m_routingTable.AddEntry(link_tuple.neighborIfaceAddr,
                                        link_tuple.neighborIfaceAddr,
                                        link_tuple.localIfaceAddr,
                                        1);
                if (link_tuple.neighborIfaceAddr == nb_tuple.neighborMainAddr)
                {
                    nb_main_addr = true;
                }
            }
        }
        if (!nb_main_addr && lt != nullptr)
        {
            m_routingTable.AddEntry(nb_tuple.neighborMainAddr,
                                    lt->neighborIfaceAddr,
                                    lt->localIfaceAddr,
                                    1);
        }
    }

    // h=2: two-hop neighbors
    for (const auto& nb2hop : m_state.GetTwoHopNeighbors())
    {
        if (m_state.FindSymNeighborTuple(nb2hop.twoHopNeighborAddr) ||
            nb2hop.twoHopNeighborAddr == m_mainAddress)
        {
            continue;
        }
        bool nb2hopOk = false;
        for (const auto& nb : m_state.GetNeighbors())
        {
            if (nb.neighborMainAddr == nb2hop.neighborMainAddr &&
                nb.willingness != Willingness::NEVER)
            {
                nb2hopOk = true;
                break;
            }
        }
        if (!nb2hopOk)
        {
            continue;
        }
        RoutingTableEntry entry;
        if (m_routingTable.Lookup(nb2hop.neighborMainAddr, entry))
        {
            m_routingTable.AddEntry(nb2hop.twoHopNeighborAddr, entry.nextAddr, entry.interface, 2);
        }
    }

    // h>=3: topology set
    for (uint32_t h = 2;; h++)
    {
        bool added = false;
        for (const auto& topo : m_state.GetTopologySet())
        {
            RoutingTableEntry destEntry;
            RoutingTableEntry lastEntry;
            bool have_dest = m_routingTable.Lookup(topo.destAddr, destEntry);
            bool have_last = m_routingTable.Lookup(topo.lastAddr, lastEntry);
            if (!have_dest && have_last && lastEntry.distance == h)
            {
                m_routingTable.AddEntry(topo.destAddr,
                                        lastEntry.nextAddr,
                                        lastEntry.interface,
                                        h + 1);
                added = true;
            }
        }
        if (!added)
        {
            break;
        }
    }

    // MID: add iface-address routes
    for (const auto& ifaceAssoc : m_state.GetIfaceAssocSet())
    {
        RoutingTableEntry entry1;
        RoutingTableEntry entry2;
        if (m_routingTable.Lookup(ifaceAssoc.mainAddr, entry1) &&
            !m_routingTable.Lookup(ifaceAssoc.ifaceAddr, entry2))
        {
            m_routingTable.AddEntry(ifaceAssoc.ifaceAddr,
                                    entry1.nextAddr,
                                    entry1.interface,
                                    entry1.distance);
        }
    }

    // HNA: build/replace HNA routing table
    Ptr<Ipv4StaticRouting> hna = m_routingTable.GetHnaRoutingTable();
    for (uint32_t i = 0; i < hna->GetNRoutes(); i++)
    {
        hna->RemoveRoute(0);
    }
    for (const auto& assocTuple : m_state.GetAssociationSet())
    {
        // Skip if we announce the same association ourselves
        bool skip = false;
        for (const auto& localAssoc : m_state.GetAssociations())
        {
            if (localAssoc.networkAddr == assocTuple.networkAddr &&
                localAssoc.netmask == assocTuple.netmask)
            {
                skip = true;
                break;
            }
        }
        if (skip)
        {
            continue;
        }

        RoutingTableEntry gwEntry;
        bool gwExists = m_routingTable.Lookup(assocTuple.gatewayAddr, gwEntry);

        uint32_t routeIndex = 0;
        for (; routeIndex < hna->GetNRoutes(); routeIndex++)
        {
            Ipv4RoutingTableEntry r = hna->GetRoute(routeIndex);
            if (r.GetDestNetwork() == assocTuple.networkAddr &&
                r.GetDestNetworkMask() == assocTuple.netmask)
            {
                break;
            }
        }

        bool addRoute = (routeIndex == hna->GetNRoutes());
        if (!addRoute && gwExists && hna->GetMetric(routeIndex) > gwEntry.distance)
        {
            hna->RemoveRoute(routeIndex);
            addRoute = true;
        }
        if (addRoute && gwExists)
        {
            hna->AddNetworkRouteTo(assocTuple.networkAddr,
                                   assocTuple.netmask,
                                   gwEntry.nextAddr,
                                   gwEntry.interface,
                                   gwEntry.distance);
        }
    }

    NS_LOG_DEBUG("Node " << m_mainAddress << ": RoutingTableComputation end.");
    m_routingTableChanged(m_routingTable.GetSize());
}

// -----------------------------------------------------------------------
// Public configuration API
// -----------------------------------------------------------------------

void
RoutingProtocol::SetMainInterface(uint32_t interface)
{
    m_mainAddress = m_ipv4->GetAddress(interface, 0).GetLocal();
}

void
RoutingProtocol::SetInterfaceExclusions(std::set<uint32_t> exceptions)
{
    m_interfaceExclusions = std::move(exceptions);
}

void
RoutingProtocol::AddHostNetworkAssociation(Ipv4Address networkAddr, Ipv4Mask netmask)
{
    for (const auto& assoc : m_state.GetAssociations())
    {
        if (assoc.networkAddr == networkAddr && assoc.netmask == netmask)
        {
            NS_LOG_INFO("HNA association for network " << networkAddr << "/" << netmask
                                                       << " already exists.");
            return;
        }
    }
    NS_LOG_INFO("Adding HNA association for network " << networkAddr << "/" << netmask << ".");
    m_state.InsertAssociation(Association{networkAddr, netmask});
}

void
RoutingProtocol::RemoveHostNetworkAssociation(Ipv4Address networkAddr, Ipv4Mask netmask)
{
    NS_LOG_INFO("Removing HNA association for network " << networkAddr << "/" << netmask << ".");
    m_state.EraseAssociation(Association{networkAddr, netmask});
}

void
RoutingProtocol::SetRoutingTableAssociation(Ptr<Ipv4StaticRouting> routingTable)
{
    // Swap returns the old association (may be null).
    Ptr<Ipv4StaticRouting> old = m_routingTable.SwapRoutingTableAssociation(routingTable);

    // Remove HNA entries that came from the old association table.
    if (old)
    {
        for (uint32_t i = 0; i < old->GetNRoutes(); i++)
        {
            Ipv4RoutingTableEntry route = old->GetRoute(i);
            if (UsesNonQbrOutgoingInterface(route))
            {
                RemoveHostNetworkAssociation(route.GetDestNetwork(), route.GetDestNetworkMask());
            }
        }
    }

    // Add HNA entries from the new association table.
    for (uint32_t i = 0; i < routingTable->GetNRoutes(); i++)
    {
        Ipv4RoutingTableEntry route = routingTable->GetRoute(i);
        if (UsesNonQbrOutgoingInterface(route))
        {
            AddHostNetworkAssociation(route.GetDestNetwork(), route.GetDestNetworkMask());
        }
    }
}

Ptr<const Ipv4StaticRouting>
RoutingProtocol::GetRoutingTableAssociation() const
{
    // Mirrors original semantics: returns the HNA routing table, not the
    // static-routing association.
    return m_routingTable.GetHnaRoutingTableConst();
}

// -----------------------------------------------------------------------
// Query accessors
// -----------------------------------------------------------------------

std::vector<RoutingTableEntry>
RoutingProtocol::GetRoutingTableEntries() const
{
    return m_routingTable.GetEntries();
}

MprSet
RoutingProtocol::GetMprSet() const
{
    return m_state.GetMprSet();
}

const MprSelectorSet&
RoutingProtocol::GetMprSelectors() const
{
    return m_state.GetMprSelectors();
}

const NeighborSet&
RoutingProtocol::GetNeighbors() const
{
    return m_state.GetNeighbors();
}

const TwoHopNeighborSet&
RoutingProtocol::GetTwoHopNeighbors() const
{
    return m_state.GetTwoHopNeighbors();
}

const TopologySet&
RoutingProtocol::GetTopologySet() const
{
    return m_state.GetTopologySet();
}

const QbrState&
RoutingProtocol::GetQbrState() const
{
    return m_state;
}

int64_t
RoutingProtocol::AssignStreams(int64_t stream)
{
    NS_LOG_FUNCTION(this << stream);
    m_uniformRandomVariable->SetStream(stream);
    return 1;
}

// -----------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------

Ipv4Address
RoutingProtocol::GetMainAddress(Ipv4Address iface_addr) const
{
    const IfaceAssocTuple* tuple = m_state.FindIfaceAssocTuple(iface_addr);
    return (tuple != nullptr) ? tuple->mainAddr : iface_addr;
}

bool
RoutingProtocol::IsMyOwnAddress(const Ipv4Address& a) const
{
    for (const auto& [sock, ifaceAddr] : m_messageHandler.m_sendSockets)
    {
        if (a == ifaceAddr.GetLocal())
        {
            return true;
        }
    }
    return false;
}

int
RoutingProtocol::Degree(const NeighborTuple& tuple)
{
    int degree = 0;
    for (const auto& nb2hop : m_state.GetTwoHopNeighbors())
    {
        if (nb2hop.neighborMainAddr == tuple.neighborMainAddr &&
            m_state.FindNeighborTuple(nb2hop.neighborMainAddr) == nullptr)
        {
            degree++;
        }
    }
    return degree;
}

bool
RoutingProtocol::UsesNonQbrOutgoingInterface(const Ipv4RoutingTableEntry& route)
{
    return m_interfaceExclusions.count(route.GetInterface()) != 0;
}

void
RoutingProtocol::Dump()
{
#ifdef NS3_LOG_ENABLE
    Time now = Simulator::Now();
    NS_LOG_DEBUG("Dumping for node with main address " << m_mainAddress);
    NS_LOG_DEBUG(" Neighbor set");
    for (const auto& nb : m_state.GetNeighbors())
    {
        NS_LOG_DEBUG("  " << nb);
    }
    NS_LOG_DEBUG(" Two-hop neighbor set");
    for (const auto& nb2 : m_state.GetTwoHopNeighbors())
    {
        if (now < nb2.expirationTime)
        {
            NS_LOG_DEBUG("  " << nb2);
        }
    }
    NS_LOG_DEBUG(" Routing table");
    for (const auto& [dest, entry] : m_routingTable.GetTableRef())
    {
        NS_LOG_DEBUG("  dest=" << dest << " --> next=" << entry.nextAddr << " via interface "
                               << entry.interface);
    }
    NS_LOG_DEBUG("");
#endif
}

} // namespace qbr
} // namespace ns3
