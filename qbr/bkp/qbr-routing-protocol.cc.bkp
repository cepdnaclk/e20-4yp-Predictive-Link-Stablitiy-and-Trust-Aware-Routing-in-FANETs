///
/// @file qbr-routing-protocol.cc
/// @brief Glue implementation for RoutingProtocol.
///
/// This file contains only the code that is genuinely "cross-cutting"
/// across all three sub-components (RoutingTable, TupleManager,
/// MessageHandler):
///
///   • GetTypeId / constructor / destructor
///   • SetIpv4, DoInitialize, DoDispose
///   • Periodic timer expire handlers (Hello/Tc/Mid/Hna)
///   • RouteOutput, RouteInput, PrintRoutingTable
///   • MprComputation, RoutingTableComputation
///   • Public query accessors (GetMprSet, GetNeighbors, …)
///   • HNA management (AddHostNetworkAssociation, …)
///   • IsMyOwnAddress, GetMainAddress, Degree, Dump
///

#define NS_LOG_APPEND_CONTEXT                                                                      \
    if (GetObject<Node>())                                                                         \
    {                                                                                              \
        std::clog << "[node " << GetObject<Node>()->GetId() << "] ";                               \
    }

#include "qbr-routing-protocol.h"

#include "qbr-repositories.h"

#include "ns3/boolean.h"
#include "ns3/enum.h"
#include "ns3/inet-socket-address.h"
#include "ns3/ipv4-header.h"
#include "ns3/ipv4-packet-info-tag.h"
#include "ns3/ipv4-route.h"
#include "ns3/ipv4-routing-table-entry.h"
#include "ns3/log.h"
#include "ns3/names.h"
#include "ns3/simulator.h"
#include "ns3/socket-factory.h"
#include "ns3/trace-source-accessor.h"
#include "ns3/udp-socket-factory.h"
#include "ns3/uinteger.h"

#include <iomanip>
#include <iostream>

// -----------------------------------------------------------------------
// Convenience macros (mirrors the originals)
// -----------------------------------------------------------------------

#define DELAY(time)                                                                                \
    (((time) < (Simulator::Now())) ? Seconds(0.000001)                                             \
                                   : (time - Simulator::Now() + Seconds(0.000001)))

#define QBR_REFRESH_INTERVAL m_helloInterval
#define QBR_NEIGHB_HOLD_TIME Time(3 * QBR_REFRESH_INTERVAL)
#define QBR_TOP_HOLD_TIME Time(3 * m_tcInterval)
#define QBR_DUP_HOLD_TIME Seconds(30)
#define QBR_MID_HOLD_TIME Time(3 * m_midInterval)
#define QBR_HNA_HOLD_TIME Time(3 * m_hnaInterval)

#define QBR_MAXJITTER (m_helloInterval.GetSeconds() / 4)
#define QBR_MAX_SEQ_NUM 65535
#define JITTER (Seconds(m_uniformRandomVariable->GetValue(0, QBR_MAXJITTER)))

namespace ns3
{

NS_LOG_COMPONENT_DEFINE("QbrRoutingProtocol");

namespace qbr
{

// -----------------------------------------------------------------------
// Local enum definitions (only used in this TU)
// -----------------------------------------------------------------------

enum class LinkType : uint8_t
{
    UNSPEC_LINK = 0,
    ASYM_LINK = 1,
    SYM_LINK = 2,
    LOST_LINK = 3,
};

enum class NeighborType : uint8_t
{
    NOT_NEIGH = 0,
    SYM_NEIGH = 1,
    MPR_NEIGH = 2,
};

// -----------------------------------------------------------------------
// ns-3 boilerplate
// -----------------------------------------------------------------------

NS_OBJECT_ENSURE_REGISTERED(RoutingProtocol);

const uint16_t RoutingProtocol::QBR_PORT_NUMBER = 9900;

TypeId
RoutingProtocol::GetTypeId()
{
    static TypeId tid =
        TypeId("ns3::qbr::RoutingProtocol")
            .SetParent<Ipv4RoutingProtocol>()
            .SetGroupName("Qbr")
            .AddConstructor<RoutingProtocol>()
            .AddAttribute("HelloInterval",
                          "HELLO messages emission interval.",
                          TimeValue(Seconds(2)),
                          MakeTimeAccessor(&RoutingProtocol::m_helloInterval),
                          MakeTimeChecker())
            .AddAttribute("TcInterval",
                          "TC messages emission interval.",
                          TimeValue(Seconds(5)),
                          MakeTimeAccessor(&RoutingProtocol::m_tcInterval),
                          MakeTimeChecker())
            .AddAttribute("MidInterval",
                          "MID messages emission interval.",
                          TimeValue(Seconds(5)),
                          MakeTimeAccessor(&RoutingProtocol::m_midInterval),
                          MakeTimeChecker())
            .AddAttribute("HnaInterval",
                          "HNA messages emission interval.",
                          TimeValue(Seconds(5)),
                          MakeTimeAccessor(&RoutingProtocol::m_hnaInterval),
                          MakeTimeChecker())
            .AddAttribute("Willingness",
                          "Willingness of a node to carry and forward traffic.",
                          EnumValue(Willingness::DEFAULT),
                          MakeEnumAccessor<Willingness>(&RoutingProtocol::m_willingness),
                          MakeEnumChecker(Willingness::NEVER,
                                          "never",
                                          Willingness::LOW,
                                          "low",
                                          Willingness::DEFAULT,
                                          "default",
                                          Willingness::HIGH,
                                          "high",
                                          Willingness::ALWAYS,
                                          "always"))
            // Trace sources forward from the MessageHandler member.
            .AddTraceSource("Rx",
                            "Receive QBR packet.",
                            MakeTraceSourceAccessor(&RoutingProtocol::m_rxPacketTrace),
                            "ns3::qbr::RoutingProtocol::PacketTxRxTracedCallback")
            .AddTraceSource("Tx",
                            "Send QBR packet.",
                            MakeTraceSourceAccessor(&RoutingProtocol::m_txPacketTrace),
                            "ns3::qbr::RoutingProtocol::PacketTxRxTracedCallback")
            .AddTraceSource("RoutingTableChanged",
                            "The QBR routing table has changed.",
                            MakeTraceSourceAccessor(&RoutingProtocol::m_routingTableChanged),
                            "ns3::qbr::RoutingProtocol::TableChangeTracedCallback");
    return tid;
}

// -----------------------------------------------------------------------
// Construction / destruction
// -----------------------------------------------------------------------

RoutingProtocol::RoutingProtocol()
    : m_state(),
      m_routingTable(),
      m_tupleManager(m_state),
      m_messageHandler(),
      m_helloTimer(Timer::CANCEL_ON_DESTROY),
      m_tcTimer(Timer::CANCEL_ON_DESTROY),
      m_midTimer(Timer::CANCEL_ON_DESTROY),
      m_hnaTimer(Timer::CANCEL_ON_DESTROY),
      m_ipv4(nullptr)
{
    m_uniformRandomVariable = CreateObject<UniformRandomVariable>();

    // Create the HNA table and hand ownership to RoutingTable immediately.
    m_routingTable.SetHnaRoutingTable(CreateObject<Ipv4StaticRouting>());

    // Ipv4 is not available yet; SetIpv4() will fill this in.
    m_routingTable.SetIpv4(nullptr);
}

RoutingProtocol::~RoutingProtocol()
{
}

// -----------------------------------------------------------------------
// SetIpv4 — wire everything up
// -----------------------------------------------------------------------

void
RoutingProtocol::SetIpv4(Ptr<Ipv4> ipv4)
{
    NS_ASSERT(ipv4);
    NS_ASSERT(!m_ipv4);
    NS_LOG_DEBUG("Created qbr::RoutingProtocol");

    m_ipv4 = ipv4;
    m_routingTable.GetHnaRoutingTable()->SetIpv4(ipv4);

    // ---- RoutingTable ----
    m_routingTable.SetIpv4(ipv4);
    // HnaRoutingTable was already given to RoutingTable in the constructor.

    // ---- TupleManager wiring ----
    m_tupleManager.SetNode(GetObject<Node>());
    m_tupleManager.SetMainAddress(m_mainAddress); // updated again in DoInitialize
    m_tupleManager.SetNeighborLossCallback([this]() {
        MprComputation();
        RoutingTableComputation();
    });

    // ---- MessageHandler wiring ----
    m_messageHandler.SetNode(GetObject<Node>());
    m_messageHandler.SetMainAddress(m_mainAddress);
    m_messageHandler.SetState(&m_state);
    m_messageHandler.SetIpv4(ipv4);
    m_messageHandler.SetInterfaceExclusions(&m_interfaceExclusions);
    m_messageHandler.SetWillingness(m_willingness);
    m_messageHandler.SetHelloInterval(m_helloInterval);
    m_messageHandler.SetNeighHoldTime(QBR_NEIGHB_HOLD_TIME);
    m_messageHandler.SetTopHoldTime(QBR_TOP_HOLD_TIME);
    m_messageHandler.SetMidHoldTime(QBR_MID_HOLD_TIME);
    m_messageHandler.SetHnaHoldTime(QBR_HNA_HOLD_TIME);
    m_messageHandler.SetPortNumber(QBR_PORT_NUMBER);
    m_messageHandler.SetJitterCallback([this]() { return JITTER; });
    m_messageHandler.SetGetAnsnCallback([this]() { return m_tupleManager.GetAnsn(); });

    // Forward Tx/Rx traces: MessageHandler fires these callbacks, which in turn
    // invoke the TracedCallbacks on RoutingProtocol so ns-3's trace system works.
    m_messageHandler.SetRxTraceCallback(
        [this](const PacketHeader& h, const MessageList& m) { m_rxPacketTrace(h, m); });
    m_messageHandler.SetTxTraceCallback(
        [this](const PacketHeader& h, const MessageList& m) { m_txPacketTrace(h, m); });

    // Periodic-timer handlers
    m_messageHandler.SetRoutingTableComputationCallback([this]() { RoutingTableComputation(); });
    m_messageHandler.SetMprComputationCallback([this]() { MprComputation(); });

    // Tuple-mutation forwarding  (MessageHandler → TupleManager)
    m_messageHandler.SetAddDuplicateTupleCallback(
        [this](const DuplicateTuple& t) { m_tupleManager.AddDuplicateTuple(t); });
    m_messageHandler.SetAddTopologyTupleCallback(
        [this](const TopologyTuple& t) { m_tupleManager.AddTopologyTuple(t); });
    m_messageHandler.SetAddIfaceAssocTupleCallback(
        [this](const IfaceAssocTuple& t) { m_tupleManager.AddIfaceAssocTuple(t); });
    m_messageHandler.SetAddAssociationTupleCallback(
        [this](const AssociationTuple& t) { m_tupleManager.AddAssociationTuple(t); });
    m_messageHandler.SetAddTwoHopNeighborTupleCallback(
        [this](const TwoHopNeighborTuple& t) { m_tupleManager.AddTwoHopNeighborTuple(t); });
    m_messageHandler.SetAddMprSelectorTupleCallback(
        [this](const MprSelectorTuple& t) { m_tupleManager.AddMprSelectorTuple(t); });
    m_messageHandler.SetLinkTupleAddedCallback(
        [this](const LinkTuple& t, Willingness w) { m_tupleManager.LinkTupleAdded(t, w); });
    m_messageHandler.SetLinkTupleUpdatedCallback(
        [this](const LinkTuple& t, Willingness w) { m_tupleManager.LinkTupleUpdated(t, w); });

    // Timer-scheduling forwarding (MessageHandler → m_events / TupleManager)
    m_messageHandler.SetScheduleDupExpireCallback(
        [this](Ipv4Address addr, uint16_t seq, Time delay) {
            m_events.Track(Simulator::Schedule(delay,
                                               &TupleManager::DupTupleTimerExpire,
                                               &m_tupleManager,
                                               addr,
                                               seq));
        });
    m_messageHandler.SetScheduleTopologyExpireCallback(
        [this](Ipv4Address dest, Ipv4Address last, Time delay) {
            m_events.Track(Simulator::Schedule(delay,
                                               &TupleManager::TopologyTupleTimerExpire,
                                               &m_tupleManager,
                                               dest,
                                               last));
        });
    m_messageHandler.SetScheduleIfaceAssocExpireCallback([this](Ipv4Address iface, Time delay) {
        m_events.Track(Simulator::Schedule(delay,
                                           &TupleManager::IfaceAssocTupleTimerExpire,
                                           &m_tupleManager,
                                           iface));
    });
    m_messageHandler.SetScheduleAssocExpireCallback(
        [this](Ipv4Address gw, Ipv4Address net, Ipv4Mask mask, Time delay) {
            m_events.Track(Simulator::Schedule(delay,
                                               &TupleManager::AssociationTupleTimerExpire,
                                               &m_tupleManager,
                                               gw,
                                               net,
                                               mask));
        });
    m_messageHandler.SetScheduleNb2hopExpireCallback(
        [this](Ipv4Address nbMain, Ipv4Address twoHop, Time delay) {
            m_events.Track(Simulator::Schedule(delay,
                                               &TupleManager::Nb2hopTupleTimerExpire,
                                               &m_tupleManager,
                                               nbMain,
                                               twoHop));
        });
    m_messageHandler.SetScheduleMprSelExpireCallback([this](Ipv4Address main, Time delay) {
        m_events.Track(Simulator::Schedule(delay,
                                           &TupleManager::MprSelTupleTimerExpire,
                                           &m_tupleManager,
                                           main));
    });
    m_messageHandler.SetScheduleLinkTupleExpireCallback([this](Ipv4Address nbIface, Time delay) {
        m_events.Track(Simulator::Schedule(delay,
                                           &TupleManager::LinkTupleTimerExpire,
                                           &m_tupleManager,
                                           nbIface));
    });

    // Timer setup
    m_helloTimer.SetFunction(&RoutingProtocol::HelloTimerExpire, this);
    m_tcTimer.SetFunction(&RoutingProtocol::TcTimerExpire, this);
    m_midTimer.SetFunction(&RoutingProtocol::MidTimerExpire, this);
    m_hnaTimer.SetFunction(&RoutingProtocol::HnaTimerExpire, this);

    // Sequence-number counters: initialise in MessageHandler via wired
    // state; the original code also reset m_ansn here.
    m_tupleManager.ResetAnsn(QBR_MAX_SEQ_NUM);
}

void
RoutingProtocol::DoDispose()
{
    m_ipv4 = nullptr;

    // Release the two Ipv4StaticRouting objects owned by RoutingTable.
    m_routingTable.DisposeStaticRoutes();

    auto& recvSock = m_messageHandler.m_recvSocket;
    if (recvSock)
    {
        recvSock->Close();
        recvSock = nullptr;
    }
    for (auto& [sock, _] : m_messageHandler.m_sendSockets)
    {
        sock->Close();
    }
    m_messageHandler.m_sendSockets.clear();
    m_routingTable.Clear();

    Ipv4RoutingProtocol::DoDispose();
}

void
RoutingProtocol::DoInitialize()
{
    if (m_mainAddress == Ipv4Address())
    {
        Ipv4Address loopback("127.0.0.1");
        for (uint32_t i = 0; i < m_ipv4->GetNInterfaces(); i++)
        {
            Ipv4Address addr = m_ipv4->GetAddress(i, 0).GetLocal();
            if (addr != loopback)
            {
                m_mainAddress = addr;
                break;
            }
        }
        NS_ASSERT(m_mainAddress != Ipv4Address());
    }

    // Propagate main address to sub-components now that it is known.
    m_tupleManager.SetMainAddress(m_mainAddress);
    m_messageHandler.SetMainAddress(m_mainAddress);

    NS_LOG_DEBUG("Starting QBR on node " << m_mainAddress);

    Ipv4Address loopback("127.0.0.1");
    bool canRunQbr = false;

    for (uint32_t i = 0; i < m_ipv4->GetNInterfaces(); i++)
    {
        Ipv4Address addr = m_ipv4->GetAddress(i, 0).GetLocal();
        if (addr == loopback)
        {
            continue;
        }

        if (addr != m_mainAddress)
        {
            IfaceAssocTuple tuple;
            tuple.ifaceAddr = addr;
            tuple.mainAddr = m_mainAddress;
            m_tupleManager.AddIfaceAssocTuple(tuple);
            NS_ASSERT(GetMainAddress(addr) == m_mainAddress);
        }

        if (m_interfaceExclusions.count(i))
        {
            continue;
        }

        // Receive socket (shared across all interfaces)
        auto& recvSock = m_messageHandler.m_recvSocket;
        if (!recvSock)
        {
            recvSock = Socket::CreateSocket(GetObject<Node>(), UdpSocketFactory::GetTypeId());
            recvSock->SetAllowBroadcast(true);
            InetSocketAddress inetAddr(Ipv4Address::GetAny(), QBR_PORT_NUMBER);
            recvSock->SetRecvCallback(MakeCallback(&MessageHandler::RecvQbr, &m_messageHandler));
            if (recvSock->Bind(inetAddr))
            {
                NS_FATAL_ERROR("Failed to bind() QBR recv socket");
            }
            recvSock->SetRecvPktInfo(true);
            recvSock->ShutdownSend();
        }

        // Per-interface send socket
        Ptr<Socket> socket = Socket::CreateSocket(GetObject<Node>(), UdpSocketFactory::GetTypeId());
        socket->SetAllowBroadcast(true);
        socket->SetIpTtl(1);
        InetSocketAddress inetAddr(m_ipv4->GetAddress(i, 0).GetLocal(), QBR_PORT_NUMBER);
        socket->SetRecvCallback(MakeCallback(&MessageHandler::RecvQbr, &m_messageHandler));
        socket->BindToNetDevice(m_ipv4->GetNetDevice(i));
        if (socket->Bind(inetAddr))
        {
            NS_FATAL_ERROR("Failed to bind() QBR send socket");
        }
        socket->SetRecvPktInfo(true);
        m_messageHandler.m_sendSockets[socket] = m_ipv4->GetAddress(i, 0);
        canRunQbr = true;
    }

    if (canRunQbr)
    {
        // Schedule timers, don’t call Expire() directly
        m_helloTimer.Schedule(JITTER); // small random jitter
        m_tcTimer.Schedule(m_tcInterval);
        m_midTimer.Schedule(m_midInterval);
        m_hnaTimer.Schedule(m_hnaInterval);
        NS_LOG_DEBUG("QBR on node " << m_mainAddress << " started");
    }
}

// -----------------------------------------------------------------------
// Periodic timer handlers
// -----------------------------------------------------------------------

void
RoutingProtocol::HelloTimerExpire()
{
    m_messageHandler.SendHello();
    m_helloTimer.Schedule(m_helloInterval);
}

void
RoutingProtocol::TcTimerExpire()
{
    if (!m_state.GetMprSelectors().empty())
    {
        m_messageHandler.SendTc();
    }
    else
    {
        NS_LOG_DEBUG("Not sending any TC, no one selected me as MPR.");
    }
    m_tcTimer.Schedule(m_tcInterval);
}

void
RoutingProtocol::MidTimerExpire()
{
    m_messageHandler.SendMid();
    m_midTimer.Schedule(m_midInterval);
}

void
RoutingProtocol::HnaTimerExpire()
{
    if (!m_state.GetAssociations().empty())
    {
        m_messageHandler.SendHna();
    }
    else
    {
        NS_LOG_DEBUG("Not sending any HNA, no associations to advertise.");
    }
    m_hnaTimer.Schedule(m_hnaInterval);
}

// -----------------------------------------------------------------------
// Q-Learning
// -----------------------------------------------------------------------

std::vector<Ipv4Address>
RoutingProtocol::GetAvailableActions()
{
    std::vector<Ipv4Address> actions;

    for (const auto& nb : m_state.GetNeighbors())
    {
        if (nb.status == NeighborTuple::STATUS_SYM)
        {
            actions.push_back(nb.neighborMainAddr);
        }
    }

    return actions;
}

void
RoutingProtocol::InitializeQEntries(Ipv4Address destination)
{
    auto actions = GetAvailableActions();

    for (auto neighbor : actions)
    {
        QuantileValue q;

        if (!m_qTable.GetEntry(destination, neighbor, q))
        {
            QuantileValue init;
            init.quantiles.fill(0.0);

            m_qTable.SetEntry(destination, neighbor, init);
        }
    }
}

std::array<double, QBR_NUM_QUANTILES>
RoutingProtocol::BuildQrDqnTarget(const Ipv4Address& nextState, double reward, double gamma)
{
    std::array<double, QBR_NUM_QUANTILES> target;
    target.fill(reward);

    Ipv4Address bestAction;

    if (!m_qTable.GetBestAction(nextState, bestAction))
    {
        return target; // terminal state
    }

    QuantileValue nextDistribution;

    if (!m_qTable.GetEntry(nextState, bestAction, nextDistribution))
    {
        return target;
    }

    for (uint32_t i = 0; i < QBR_NUM_QUANTILES; ++i)
    {
        target[i] = reward + gamma * nextDistribution.quantiles[i];
    }

    return target;
}

void
RoutingProtocol::UpdateLearning(Ipv4Address state,
                                Ipv4Address action,
                                Ipv4Address nextState,
                                double reward)
{
    auto target = BuildQrDqnTarget(nextState, reward, m_gamma);

    m_qTable.UpdateQuantiles(state, action, target, m_learningRate);

    /* decay exploration */

    m_epsilon = std::max(0.01, m_epsilon * 0.999);
}

// -----------------------------------------------------------------------
// Ipv4RoutingProtocol interface
// -----------------------------------------------------------------------

void
RoutingProtocol::PrintRoutingTable(Ptr<OutputStreamWrapper> stream, Time::Unit unit) const
{
    std::ostream* os = stream->GetStream();
    std::ios savedState(nullptr);
    savedState.copyfmt(*os);
    *os << std::resetiosflags(std::ios::adjustfield) << std::setiosflags(std::ios::left);
    *os << "Node: " << m_ipv4->GetObject<Node>()->GetId() << ", Time: " << Now().As(unit)
        << ", Local time: " << m_ipv4->GetObject<Node>()->GetLocalTime().As(unit)
        << ", QBR Routing table" << std::endl;

    m_routingTable.Print(stream, unit);

    Ptr<const Ipv4StaticRouting> hna = m_routingTable.GetHnaRoutingTableConst();
    if (hna && hna->GetNRoutes() > 0)
    {
        *os << "HNA Routing Table:" << std::endl;
        hna->PrintRoutingTable(stream, unit);
    }
    else
    {
        *os << "HNA Routing Table: empty" << std::endl << std::endl;
    }
    (*os).copyfmt(savedState);
}

Ptr<Ipv4Route>
RoutingProtocol::RouteOutput(Ptr<Packet> p,
                             const Ipv4Header& header,
                             Ptr<NetDevice> oif,
                             Socket::SocketErrno& sockerr)
{
    NS_LOG_FUNCTION(this << " " << m_ipv4->GetObject<Node>()->GetId() << " "
                         << header.GetDestination() << " " << oif);

    Ptr<Ipv4Route> rtentry;
    RoutingTableEntry entry1;
    RoutingTableEntry entry2;

    if (m_routingTable.Lookup(header.GetDestination(), entry1))
    {
        if (!m_routingTable.FindSendEntry(entry1, entry2))
        {
            NS_FATAL_ERROR("FindSendEntry failure");
        }

        Ipv4Address destination = header.GetDestination();

        InitializeQEntries(destination);

        Ipv4Address nextHop;
        bool found = false;

        /* epsilon-greedy action selection */

        double r = m_uniformRandomVariable->GetValue();

        if (r < m_epsilon)
        {
            auto actions = m_qTable.GetActions(destination);

            if (!actions.empty())
            {
                uint32_t idx = m_uniformRandomVariable->GetInteger(0, actions.size() - 1);
                nextHop = actions.at(idx);
                found = true;
            }
        }
        else
        {
            found = m_qTable.GetBestAction(destination, nextHop);
        }

        /* fallback to classical routing if RL not ready */

        if (!found)
        {
            if (!m_routingTable.Lookup(destination, entry1))
            {
                sockerr = Socket::ERROR_NOROUTETOHOST;
                return nullptr;
            }

            if (!m_routingTable.FindSendEntry(entry1, entry2))
            {
                NS_FATAL_ERROR("FindSendEntry failure");
            }

            nextHop = entry2.nextAddr;
        }

        /* obtain interface from routing table */

        if (!m_routingTable.Lookup(nextHop, entry1))
        {
            sockerr = Socket::ERROR_NOROUTETOHOST;
            return nullptr;
        }

        if (!m_routingTable.FindSendEntry(entry1, entry2))
        {
            NS_FATAL_ERROR("FindSendEntry failure");
        }

        uint32_t interfaceIdx = entry2.interface;

        rtentry = Create<Ipv4Route>();

        rtentry->SetDestination(destination);
        rtentry->SetGateway(nextHop);
        rtentry->SetOutputDevice(m_ipv4->GetNetDevice(interfaceIdx));
        rtentry->SetSource(m_ipv4->GetAddress(interfaceIdx, 0).GetLocal());

        sockerr = Socket::ERROR_NOTERROR;

        NS_LOG_DEBUG("QBR node " << m_mainAddress
                                 << ": RouteOutput for dest=" << header.GetDestination()
                                 << " --> nextHop=" << nextHop << " interface=" << interfaceIdx);
    }
    else
    {
        rtentry = m_routingTable.GetHnaRoutingTable()->RouteOutput(p, header, oif, sockerr);
        if (!rtentry)
        {
            NS_LOG_DEBUG("QBR node " << m_mainAddress << ": RouteOutput for dest="
                                     << header.GetDestination() << " No route to host");
            sockerr = Socket::ERROR_NOROUTETOHOST;
        }
    }
    return rtentry;
}

bool
RoutingProtocol::RouteInput(Ptr<const Packet> p,
                            const Ipv4Header& header,
                            Ptr<const NetDevice> idev,
                            const UnicastForwardCallback& ucb,
                            const MulticastForwardCallback& mcb,
                            const LocalDeliverCallback& lcb,
                            const ErrorCallback& ecb)
{
    NS_LOG_FUNCTION(this << " " << m_ipv4->GetObject<Node>()->GetId() << " "
                         << header.GetDestination());

    Ipv4Address dst = header.GetDestination();
    Ipv4Address origin = header.GetSource();

    if (IsMyOwnAddress(origin))
    {
        return true;
    }

    NS_ASSERT(m_ipv4->GetInterfaceForDevice(idev) >= 0);
    uint32_t iif = m_ipv4->GetInterfaceForDevice(idev);

    if (m_ipv4->IsDestinationAddress(dst, iif))
    {
        if (!lcb.IsNull())
        {
            NS_LOG_LOGIC("Local delivery to " << dst);
            lcb(p, header, iif);
            return true;
        }
        else
        {
            NS_LOG_LOGIC("Null local delivery callback");
            return false;
        }
    }

    RoutingTableEntry entry1;
    RoutingTableEntry entry2;
    if (m_routingTable.Lookup(header.GetDestination(), entry1))
    {
        if (!m_routingTable.FindSendEntry(entry1, entry2))
        {
            NS_FATAL_ERROR("FindSendEntry failure");
        }
        uint32_t interfaceIdx = entry2.interface;
        Ptr<Ipv4Route> rtentry = Create<Ipv4Route>();
        rtentry->SetDestination(header.GetDestination());
        NS_ASSERT(m_ipv4->GetNAddresses(interfaceIdx) > 0);
        if (m_ipv4->GetNAddresses(interfaceIdx) > 1)
        {
            NS_FATAL_ERROR("XXX Not implemented yet:  IP aliasing and QBR");
        }
        rtentry->SetSource(m_ipv4->GetAddress(interfaceIdx, 0).GetLocal());
        rtentry->SetGateway(entry2.nextAddr);
        rtentry->SetOutputDevice(m_ipv4->GetNetDevice(interfaceIdx));
        NS_LOG_DEBUG("QBR node " << m_mainAddress << ": RouteInput for dest="
                                 << header.GetDestination() << " --> nextHop=" << entry2.nextAddr
                                 << " interface=" << entry2.interface);
        ucb(rtentry, p, header);

        /* Q-learning update */
        Ipv4Address state = header.GetDestination();
        Ipv4Address action = entry2.nextAddr;
        Ipv4Address nextState = header.GetDestination();

        /* simple reward: successful forwarding */

        double reward = 1.0;

        UpdateLearning(state, action, nextState, reward);

        return true;
    }

    NS_LOG_LOGIC("No dynamic route, check network routes");
    if (m_routingTable.GetHnaRoutingTable()->RouteInput(p, header, idev, ucb, mcb, lcb, ecb))
    {
        return true;
    }

#ifdef NS3_LOG_ENABLE
    NS_LOG_DEBUG("QBR node " << m_mainAddress << ": RouteInput for dest=" << header.GetDestination()
                             << " --> NOT FOUND; dumping table...");
    for (const auto& [dest, entry] : m_routingTable.GetTableRef())
    {
        NS_LOG_DEBUG("dest=" << dest << " --> next=" << entry.nextAddr << " via interface "
                             << entry.interface);
    }
#endif
    /* negative reward */

    Ipv4Address state = dst;
    Ipv4Address nextState = dst;

    double reward = -1.0;

    Ipv4Address action;
    if (m_qTable.GetBestAction(state, action))
    {
        UpdateLearning(state, action, nextState, reward);
    }

    return false;
}

